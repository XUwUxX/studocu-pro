{
  "manifest_version": 3,
  "name": "Studocu Cleaner",
  "version": "1.1", 
  "permissions": [
    "cookies",
    "scripting",  
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*.studocu.com/*",
    "*://*.studocu.vn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Studocu Tools",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.studocu.com/*", "*://*.studocu.vn/*"],
      "css": ["custom_style.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer_styles.css"],
      "matches": ["*://*.studocu.com/*", "*://*.studocu.vn/*"]
    }
  ]
}